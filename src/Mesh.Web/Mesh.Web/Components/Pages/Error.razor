@page "/Error"
@using System.Diagnostics

<PageTitle>Erreur — Mesh United</PageTitle>

<div style="text-align:center;padding:3rem 1rem">
    <h1 style="font-size:28px;font-weight:800;color:var(--color-text);margin:0 0 0.75rem;letter-spacing:-0.03em">
        Une erreur est survenue
    </h1>
    @if (ShowRequestId)
    {
        <p style="font-size:12px;color:var(--color-text-secondary);font-family:monospace;margin:0 0 1.5rem">
            Request ID : @RequestId
        </p>
    }
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:12px;background:var(--color-primary-network);color:white;font-size:14px;font-weight:600;text-decoration:none">
        Retour à l'accueil
    </a>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
