@page "/messages"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IMeshService Mesh
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Messages — Mesh United</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Messagerie</h1>
        <p class="page-sub">Communiquez avec les nœuds de votre réseau Mesh</p>
    </div>
</div>

@if (!Mesh.Nodes.Any())
{
    <div class="empty-state">
        <div class="empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="currentColor" aria-hidden="true">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
            </svg>
        </div>
        <h3>Aucun nœud connecté</h3>
        <p>Vérifiez que votre nœud Mesh est en ligne et joignable sur <code>/ws/node</code>.</p>
    </div>
}
else
{
    <div class="filter-bar">
        <label class="filter-label" for="node-filter">Nœud</label>
        <select id="node-filter" class="filter-select" @bind="_selectedNodeHex">
            <option value="">Tous les nœuds</option>
            @foreach (var node in Mesh.Nodes)
            {
                <option value="@node.Id.ToString("X2")">@node.Name (0x@node.Id.ToString("X2"))</option>
            }
        </select>
    </div>

    <div class="chat-wrap">
        <div class="chat-feed" @ref="_feedEl">
            @if (!AllMessages.Any())
            {
                <div class="feed-empty">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true">
                        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                    </svg>
                    <p>Aucun message pour le moment</p>
                </div>
            }
            else
            {
                @foreach (var entry in AllMessages)
                {
                    @if (entry.IsSent)
                    {
                        <div class="bubble-row bubble-row--sent">
                            <div class="bubble bubble--sent">
                                <div class="bubble-text">@entry.Text</div>
                                <div class="bubble-time">@entry.At.LocalDateTime.ToString("HH:mm:ss")</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="bubble-row bubble-row--recv">
                            <div class="bubble-recv-wrap">
                                <span class="bubble-src">0x@entry.Src.ToString("X2")</span>
                                <div class="bubble bubble--recv">
                                    <div class="bubble-text">@entry.Text</div>
                                    <div class="bubble-time">@entry.At.LocalDateTime.ToString("HH:mm:ss")</div>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>

        <div class="chat-input-bar">
            <input class="chat-input"
                   @bind="_text"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="Envoyer un message (broadcast)…" />
            <button class="chat-send-btn"
                    type="button"
                    @onclick="SendAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_text))">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                    <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                </svg>
            </button>
        </div>
    </div>
}

@code {
    private record ChatEntry(bool IsSent, byte Src, string Text, DateTimeOffset At);

    private string _text = "";
    private string _selectedNodeHex = "";
    private ElementReference _feedEl;
    private readonly List<ChatEntry> _sent = [];

    private IEnumerable<ChatEntry> AllMessages
    {
        get
        {
            var received = FilteredMessages.Select(m => new ChatEntry(false, m.Src, m.Text, m.At));
            return received.Concat(_sent).OrderBy(e => e.At);
        }
    }

    private IReadOnlyList<MeshMessage> FilteredMessages
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_selectedNodeHex))
                return Mesh.GetMessages();

            if (!byte.TryParse(_selectedNodeHex, System.Globalization.NumberStyles.HexNumber, null, out var nodeId))
                return Mesh.GetMessages();

            return Mesh.GetMessages(nodeId);
        }
    }

    protected override void OnInitialized() => Mesh.Changed += OnChanged;

    private void OnChanged(object? _, EventArgs __) => InvokeAsync(async () =>
    {
        StateHasChanged();
        await ScrollToBottom();
    });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await ScrollToBottom();
    }

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("scrollToBottom", _feedEl); }
        catch { }
    }

    private async Task SendAsync()
    {
        var text = _text.Trim();
        if (string.IsNullOrEmpty(text)) return;

        _text = "";
        _sent.Add(new ChatEntry(true, 0x00, text, DateTimeOffset.Now));
        await Mesh.SendAsync(0xFF, text);
        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendAsync();
    }

    public void Dispose() => Mesh.Changed -= OnChanged;
}
