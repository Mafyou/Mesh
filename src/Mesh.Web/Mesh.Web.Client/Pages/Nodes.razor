@page "/nodes"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IMeshService Mesh
@implements IDisposable

<PageTitle>Nœuds — Mesh United</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Nœuds du réseau</h1>
        <p class="page-sub">Liste et topologie des nœuds Mesh connectés</p>
    </div>
    @if (Mesh.Nodes.Any())
    {
        <div class="node-count-badge">
            @Mesh.Nodes.Count nœud@(Mesh.Nodes.Count != 1 ? "s" : "") en ligne
        </div>
    }
</div>

@if (!Mesh.Nodes.Any())
{
    <div class="empty-state">
        <div class="empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="currentColor" aria-hidden="true">
                <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/>
            </svg>
        </div>
        <h3>Aucun nœud détecté</h3>
        <p>Le nœud ESP32 doit se connecter en WebSocket sur <code>/ws/node</code> et s'identifier avec un premier frame <code>[nodeId][nom]</code>.</p>
    </div>
}
else
{
    <!-- Topology -->
    <div class="section-header">
        <h2 class="section-title">Topologie observée</h2>
    </div>

    <div class="topology-card">
        <svg class="topology-graph" viewBox="0 0 520 280" role="img" aria-label="Topologie mesh observée">
            @foreach (var edge in Mesh.Topology.Where(e => e.Dst != 0xFF && _positions.ContainsKey(e.Src) && _positions.ContainsKey(e.Dst)))
            {
                var src = _positions[edge.Src];
                var dst = _positions[edge.Dst];
                <line x1="@src.X" y1="@src.Y" x2="@dst.X" y2="@dst.Y" class="topo-edge" />
            }

            @foreach (var node in Mesh.Nodes)
            {
                var pt = _positions[node.Id];
                <g>
                    <circle cx="@pt.X" cy="@pt.Y" r="22" class="topo-node" />
                    <foreignObject x="@(pt.X - 18)" y="@(pt.Y - 10)" width="36" height="20">
                        <div xmlns="http://www.w3.org/1999/xhtml" class="topo-label-box">@node.Id.ToString("X2")</div>
                    </foreignObject>
                </g>
                <foreignObject x="@(pt.X - 55)" y="@(pt.Y + 28)" width="110" height="20">
                    <div xmlns="http://www.w3.org/1999/xhtml" class="topo-name-box">@node.Name</div>
                </foreignObject>
            }
        </svg>
    </div>

    <!-- Node cards -->
    <div class="section-header" style="margin-top: 2rem;">
        <h2 class="section-title">Nœuds connectés</h2>
    </div>

    <div class="node-grid">
        @foreach (var node in Mesh.Nodes)
        {
            var lastMsg = Mesh.GetMessages(node.Id).LastOrDefault();
            <div class="node-card">
                <div class="node-avatar">@node.Id.ToString("X2")</div>
                <div class="node-info">
                    <div class="node-name">@node.Name</div>
                    <div class="node-meta">
                        <span class="node-id">0x@node.Id.ToString("X2")</span>
                        &middot; Connecté @node.ConnectedAt.LocalDateTime.ToString("HH:mm")
                    </div>
                    <div class="node-row">
                        <span class="node-detail-label">Dernière activité</span>
                        <span class="node-detail-value">@node.LastSeen.LocalDateTime.ToString("HH:mm:ss")</span>
                    </div>
                    @if (lastMsg != default)
                    {
                        <div class="node-last-msg">"@(lastMsg.Text.Length > 45 ? lastMsg.Text[..45] + "…" : lastMsg.Text)"</div>
                    }
                </div>
                <span class="node-status">En ligne</span>
            </div>
        }
    </div>

    <!-- Links -->
    @if (Mesh.Topology.Any())
    {
        <div class="section-header" style="margin-top: 2rem;">
            <h2 class="section-title">Liens observés</h2>
            <span class="link-count">@Mesh.Topology.Count lien@(Mesh.Topology.Count != 1 ? "s" : "")</span>
        </div>

        <div class="links-table-wrap">
            <table class="links-table">
                <thead>
                    <tr>
                        <th>Source</th>
                        <th>Destination</th>
                        <th>Messages</th>
                        <th>Dernière activité</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var edge in Mesh.Topology)
                    {
                        <tr>
                            <td><span class="node-pill">0x@edge.Src.ToString("X2")</span></td>
                            <td><span class="node-pill">@(edge.Dst == 0xFF ? "broadcast" : $"0x{edge.Dst:X2}")</span></td>
                            <td><span class="weight-badge">@edge.Weight</span></td>
                            <td class="time-cell">@edge.LastSeen.LocalDateTime.ToString("HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private Dictionary<byte, (double X, double Y)> _positions = [];

    protected override void OnInitialized()
    {
        Mesh.Changed += OnChanged;
        RebuildPositions();
    }

    private void OnChanged(object? _, EventArgs __)
    {
        RebuildPositions();
        _ = InvokeAsync(StateHasChanged);
    }

    private void RebuildPositions()
    {
        var nodes = Mesh.Nodes;
        if (!nodes.Any())
        {
            _positions = [];
            return;
        }

        const double cx = 260, cy = 140, r = 100;
        var ordered = nodes.OrderBy(n => n.Id).ToArray();
        var result = new Dictionary<byte, (double, double)>();

        for (var i = 0; i < ordered.Length; i++)
        {
            var angle = Math.PI * 2 * i / ordered.Length - Math.PI / 2;
            result[ordered[i].Id] = (cx + r * Math.Cos(angle), cy + r * Math.Sin(angle));
        }

        _positions = result;
    }

    public void Dispose() => Mesh.Changed -= OnChanged;
}
