@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IMeshService Mesh
@implements IDisposable

<PageTitle>Réseau — Mesh United</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">État du réseau</h1>
        <p class="page-sub">Vue d'ensemble en temps réel de votre réseau Mesh LoRa</p>
    </div>
    <div class="live-badge @(Mesh.Nodes.Any() ? "live-badge--on" : "live-badge--off")">
        <span class="live-dot"></span>
        @(Mesh.Nodes.Any() ? "En ligne" : "Aucun nœud")
    </div>
</div>

<!-- Stat cards -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon stat-icon--nodes">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@Mesh.Nodes.Count</div>
            <div class="stat-label">Nœuds connectés</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon--messages">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@Mesh.Messages.Count</div>
            <div class="stat-label">Messages reçus</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon--lora">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3a4.237 4.237 0 0 0-6 0zm-4-4 2 2a7.074 7.074 0 0 1 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">868</div>
            <div class="stat-label">MHz · SF10 · 125 kHz</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon--links">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@Mesh.Topology.Count</div>
            <div class="stat-label">Liens observés</div>
        </div>
    </div>
</div>

<!-- Node list -->
@if (Mesh.Nodes.Any())
{
    <div class="section-header">
        <h2 class="section-title">Nœuds actifs</h2>
        <a href="nodes" class="section-link">Voir tout →</a>
    </div>

    <div class="node-grid">
        @foreach (var node in Mesh.Nodes)
        {
            var lastMsg = Mesh.GetMessages(node.Id).LastOrDefault();
            <div class="node-card">
                <div class="node-avatar">@node.Id.ToString("X2")</div>
                <div class="node-info">
                    <div class="node-name">@node.Name</div>
                    <div class="node-meta">Connecté @node.ConnectedAt.LocalDateTime.ToString("HH:mm")</div>
                    @if (lastMsg != default)
                    {
                        <div class="node-last-msg">"@(lastMsg.Text.Length > 40 ? lastMsg.Text[..40] + "…" : lastMsg.Text)"</div>
                    }
                </div>
                <span class="node-status">En ligne</span>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="currentColor" aria-hidden="true">
                <path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3a4.237 4.237 0 0 0-6 0zm-4-4 2 2a7.074 7.074 0 0 1 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/>
            </svg>
        </div>
        <h3>Aucun nœud détecté</h3>
        <p>Assurez-vous que votre ESP32 est alimenté et que la liaison WebSocket est active sur <code>/ws/node</code>.</p>
    </div>
}

<!-- Recent messages -->
@if (Mesh.Messages.Any())
{
    <div class="section-header" style="margin-top: 2rem;">
        <h2 class="section-title">Messages récents</h2>
        <a href="messages" class="section-link">Voir tout →</a>
    </div>

    <div class="recent-messages">
        @foreach (var msg in Mesh.Messages.TakeLast(5).Reverse())
        {
            <div class="recent-msg">
                <span class="recent-msg-src">0x@msg.Src.ToString("X2")</span>
                <span class="recent-msg-text">@msg.Text</span>
                <span class="recent-msg-time">@msg.At.LocalDateTime.ToString("HH:mm:ss")</span>
            </div>
        }
    </div>
}

@code {
    protected override void OnInitialized() => Mesh.Changed += OnChanged;
    private void OnChanged(object? _, EventArgs __) => InvokeAsync(StateHasChanged);
    public void Dispose() => Mesh.Changed -= OnChanged;
}
