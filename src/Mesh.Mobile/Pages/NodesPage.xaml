<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mesh.Mobile.ViewModels"
             xmlns:conv="clr-namespace:Mesh.Mobile.Converters"
             xmlns:ble="clr-namespace:Plugin.BLE.Abstractions.Contracts;assembly=Plugin.BLE"
             xmlns:models="clr-namespace:Mesh.Mobile.Core.Models;assembly=Mesh.Mobile.Core"
             x:Class="Mesh.Mobile.Pages.NodesPage"
             x:DataType="vm:NodesPageViewModel"
             Title="Nœuds du réseau">

    <ContentPage.Resources>
        <conv:FirstCharConverter x:Key="FirstCharConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="0"
          x:Name="RootGrid">

        <!-- Header -->
        <StackLayout Grid.Row="0"
                     Padding="16,16,16,12"
                     Spacing="4"
                     BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource DarkCardBg}}">
            <Label Text="Nœuds Mesh LoRa détectés via Bluetooth LE."
                   Style="{StaticResource TextSmall}" />
        </StackLayout>

        <BoxView Grid.Row="0"
                 Style="{StaticResource Separator}"
                 Margin="0"
                 VerticalOptions="End" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*,Auto,Auto"
              RowSpacing="8"
              Padding="16,12,16,16">

            <!-- Scan bar -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="{Binding StatusText}"
                       Style="{StaticResource MicroLabel}"
                       VerticalTextAlignment="Center" />
                <Button Grid.Column="1"
                        Text="QR"
                        Command="{Binding ShowQrCodeCommand}"
                        IsVisible="{Binding IsConnected}"
                        Style="{StaticResource ButtonPrimary}"
                        HeightRequest="40"
                        WidthRequest="50"
                        FontSize="14" />
                <Button Grid.Column="2"
                        Text="{Binding ScanButtonText}"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding ScanButtonEnabled}"
                        Style="{StaticResource ButtonPrimary}"
                        HeightRequest="40"
                        FontSize="14" />
            </Grid>

            <!-- Device list -->
            <CollectionView Grid.Row="1"
                            x:Name="DevicesCollectionView"
                            ItemsSource="{Binding DiscoveredDevices}"
                            SelectionMode="Single"
                            SelectionChanged="OnDeviceSelected">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <StackLayout Padding="20,60"
                                 Spacing="12"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                        <Label Text="📡"
                               FontSize="48"
                               HorizontalOptions="Center" />
                        <Label Text="Aucun nœud Mesh détecté"
                               Style="{StaticResource TitleCard}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Assurez-vous que votre ESP32 est allume, visible en BLE, et a portee du telephone."
                               Style="{StaticResource MicroLabel}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               MaximumWidthRequest="280" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="ble:IDevice">
                        <Border Style="{StaticResource CardDefault}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">

                                <!-- Avatar -->
                                <Border Grid.Column="0"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2563EB" Offset="0" />
                                            <GradientStop Color="#16A34A" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="{Binding Name, Converter={StaticResource FirstCharConverter}}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Info -->
                                <StackLayout Grid.Column="1"
                                             Spacing="3"
                                             VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           Style="{StaticResource TitleCard}"
                                           FontSize="15"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Id}"
                                           Style="{StaticResource MicroLabel}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Rssi, StringFormat='{0} dBm'}"
                                           Style="{StaticResource MicroLabel}" />
                                </StackLayout>

                                <!-- Arrow -->
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark={StaticResource DarkTextSecondary}}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <!-- Mesh nodes section header -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto"
                  Margin="0,4,0,0">
                <Label Grid.Column="0"
                       Text="Nœuds vus sur le réseau LoRa"
                       Style="{StaticResource MicroLabel}"
                       FontAttributes="Bold"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1"
                       Text="{Binding MeshNodesCount, StringFormat='{0} nœud(s)'}"
                       Style="{StaticResource MicroLabel}"
                       VerticalTextAlignment="Center" />
            </Grid>

            <!-- Mesh nodes list -->
            <CollectionView Grid.Row="3"
                            ItemsSource="{Binding MeshNodes}"
                            HeightRequest="180">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <Label Text="Aucun nœud Mesh détecté sur le réseau"
                           Style="{StaticResource MicroLabel}"
                           HorizontalOptions="Center"
                           Margin="0,8" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:NodeContact">
                        <Border Style="{StaticResource CardDefault}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">

                                <!-- Node ID avatar -->
                                <Border Grid.Column="0"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        Padding="0"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0" />
                                            <GradientStop Color="#DB2777" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="{Binding Label}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="11"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Telemetry info -->
                                <StackLayout Grid.Column="1"
                                             Spacing="2"
                                             VerticalOptions="Center">
                                    <Label Text="{Binding Label}"
                                           Style="{StaticResource TitleCard}"
                                           FontSize="14" />
                                    <StackLayout Orientation="Horizontal"
                                                 Spacing="8"
                                                 IsVisible="{Binding HasTelemetry}">
                                        <Label Text="{Binding BatteryLabel}"
                                               Style="{StaticResource MicroLabel}" />
                                        <Label Text="{Binding UptimeLabel}"
                                               Style="{StaticResource MicroLabel}" />
                                    </StackLayout>
                                    <Label Text="{Binding SignalLabel}"
                                           Style="{StaticResource MicroLabel}"
                                           IsVisible="{Binding IsDirectNeighbor}" />
                                </StackLayout>

                                <!-- Direct neighbor indicator -->
                                <Border Grid.Column="2"
                                        BackgroundColor="#16A34A"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 6"
                                        Padding="6,3"
                                        VerticalOptions="Center"
                                        IsVisible="{Binding IsDirectNeighbor}">
                                    <Label Text="Direct"
                                           TextColor="White"
                                           FontSize="11"
                                           FontAttributes="Bold" />
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- QR code overlay -->
        <Grid Grid.RowSpan="2"
              IsVisible="{Binding IsQrVisible}"
              BackgroundColor="#CC000000">
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource DarkCardBg}}"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Padding="24"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="300">
                <StackLayout Spacing="16">
                    <Label Text="Partager ce nœud"
                           Style="{StaticResource TitleCard}"
                           FontSize="18"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding ConnectedNodeInfo}"
                           Style="{StaticResource MicroLabel}"
                           HorizontalOptions="Center" />
                    <Image Source="{Binding QrCodeImageSource}"
                           WidthRequest="220"
                           HeightRequest="220"
                           HorizontalOptions="Center"
                           Aspect="AspectFit" />
                    <Label Text="Scannez ce QR pour ajouter ce nœud"
                           Style="{StaticResource MicroLabel}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Fermer"
                            Command="{Binding HideQrCodeCommand}"
                            Style="{StaticResource ButtonPrimary}" />
                </StackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
