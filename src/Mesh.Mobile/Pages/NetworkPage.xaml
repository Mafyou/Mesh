<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mesh.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Mesh.Mobile.Pages.NetworkPage"
             x:DataType="vm:NetworkPageViewModel"
             Title="Réseau">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <StackLayout Grid.Row="0"
                     Padding="16,16,16,12"
                     Spacing="4"
                     BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource DarkCardBg}}">
            <Label Text="État de la connectivité Mesh."
                   Style="{StaticResource TextSmall}" />
        </StackLayout>
        <BoxView Grid.Row="0" Style="{StaticResource Separator}" Margin="0" VerticalOptions="End" />

        <ScrollView Grid.Row="1">
            <StackLayout Padding="16" Spacing="16">

                <!-- BLE connection -->
                <StackLayout Spacing="8">
                    <Label Text="Bluetooth LE" Style="{StaticResource TitleCard}" />
                    <Border Style="{StaticResource CardDefault}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="12" HeightRequest="12" Padding="0"
                                    BackgroundColor="{Binding BleStatusColor}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 6"
                                    VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding BleStatusText}"
                                   Style="{StaticResource TextSmall}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding NodeCount, StringFormat='{0} vu(s)'}"
                                   Style="{StaticResource MicroLabel}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </StackLayout>

                <!-- Radio parameters (visible only when connected) -->
                <StackLayout Spacing="8" IsVisible="{Binding IsNodeConnected}">
                    <Label Text="Radio LoRa" Style="{StaticResource TitleCard}" />
                    <Border Style="{StaticResource CardDefault}">
                        <StackLayout Spacing="4">
                            <Label Text="Paramètres du nœud actif"
                                   Style="{StaticResource MicroLabel}" />
                            <Label Text="{Binding RadioSummary}"
                                   Style="{StaticResource TextSmall}"
                                   FontAttributes="Bold" />
                        </StackLayout>
                    </Border>
                    <Border Style="{StaticResource CardDefault}">
                        <StackLayout Spacing="4">
                            <Label Text="Firmware"
                                   Style="{StaticResource MicroLabel}" />
                            <Label Text="{Binding FirmwareSummary}"
                                   Style="{StaticResource TextSmall}" />
                        </StackLayout>
                    </Border>
                </StackLayout>

                <!-- Prompt when not connected -->
                <Border Style="{StaticResource CardDefault}"
                        IsVisible="{Binding IsNodeConnected, Converter={StaticResource InvertBool}}">
                    <StackLayout Spacing="6" HorizontalOptions="Center" Padding="8">
                        <Label Text="Aucun nœud connecté"
                               Style="{StaticResource TitleCard}"
                               HorizontalOptions="Center" />
                        <Label Text="Connectez-vous à un nœud MeshCore depuis l'onglet Nœuds."
                               Style="{StaticResource MicroLabel}"
                               HorizontalTextAlignment="Center" />
                    </StackLayout>
                </Border>

                <BoxView Style="{StaticResource Separator}" />

                <!-- Stats -->
                <StackLayout Spacing="8">
                    <Label Text="Session" Style="{StaticResource TitleCard}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Style="{StaticResource CardDefault}">
                            <StackLayout Spacing="4">
                                <Label Text="Nœuds BLE détectés"
                                       Style="{StaticResource MicroLabel}" />
                                <Label Text="{Binding NodeCount}"
                                       FontSize="28" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource LightAccentLora}, Dark={StaticResource DarkAccentLora}}" />
                            </StackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardDefault}">
                            <StackLayout Spacing="4">
                                <Label Text="Messages reçus"
                                       Style="{StaticResource MicroLabel}" />
                                <Label Text="{Binding MessageCount}"
                                       FontSize="28" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource LightPrimaryNetwork}, Dark={StaticResource DarkPrimaryNetwork}}" />
                            </StackLayout>
                        </Border>
                    </Grid>
                </StackLayout>

                <BoxView Style="{StaticResource Separator}" />

                <Button Text="{Binding ScanButtonText}"
                        Command="{Binding ScanCommand}"
                        Style="{StaticResource ButtonSecondary}" />
                <Label Text="{Binding ScanStatusText}"
                       Style="{StaticResource MicroLabel}"
                       HorizontalOptions="Center" />

            </StackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
