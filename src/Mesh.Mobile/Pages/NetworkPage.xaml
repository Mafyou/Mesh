<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mesh.Mobile.ViewModels"
             x:Class="Mesh.Mobile.Pages.NetworkPage"
             x:DataType="vm:NetworkPageViewModel"
             Title="État du réseau">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="0">

        <StackLayout Grid.Row="0"
                     Padding="16,16,16,12"
                     Spacing="4"
                     BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource DarkCardBg}}">
            <Label Text="Vue d'ensemble rapide de la connectivité Mesh."
                   Style="{StaticResource TextSmall}" />
        </StackLayout>

        <BoxView Grid.Row="0"
                 Style="{StaticResource Separator}"
                 Margin="0"
                 VerticalOptions="End" />

        <ScrollView Grid.Row="1">
            <StackLayout Padding="16"
                         Spacing="16">

                <Border Style="{StaticResource CardDefault}">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Bluetooth LE"
                                   Style="{StaticResource TitleCard}" />
                            <Label Text="État de la connexion locale"
                                   Style="{StaticResource TextSmall}" />
                        </StackLayout>
                        <Border Grid.Column="1"
                                WidthRequest="12"
                                HeightRequest="12"
                                Padding="0"
                                BackgroundColor="{Binding BleStatusColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardDefault}">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Réseau LoRa"
                                   Style="{StaticResource TitleCard}" />
                            <Label Text="Portee estimee : ~2.5 km  |  868 MHz  |  SF10"
                                   Style="{StaticResource TextSmall}" />
                        </StackLayout>
                        <Border Grid.Column="1"
                                WidthRequest="12"
                                HeightRequest="12"
                                Padding="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightAccentLora}, Dark={StaticResource DarkAccentLora}}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardDefault}">
                    <StackLayout Spacing="8">
                        <Label Text="Qualité du signal"
                               Style="{StaticResource TitleCard}" />
                        <ProgressBar Progress="{Binding SignalProgress}"
                                     HeightRequest="6" />
                        <Label Text="{Binding SignalText}"
                               Style="{StaticResource TextSmall}"
                               HorizontalTextAlignment="End" />
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardDefault}">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="12">
                        <Label Grid.Row="0"
                               Text="Statistiques reseau"
                               Style="{StaticResource TitleCard}" />
                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <StackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Nœuds détectés"
                                       Style="{StaticResource TextSmall}" />
                                <Label Text="{Binding NodeCount}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource LightAccentLora}, Dark={StaticResource DarkAccentLora}}" />
                            </StackLayout>
                            <StackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Messages reçus"
                                       Style="{StaticResource TextSmall}" />
                                <Label Text="{Binding MessageCount}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource LightPrimaryNetwork}, Dark={StaticResource DarkPrimaryNetwork}}" />
                            </StackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <Button Text="{Binding ScanButtonText}"
                        Command="{Binding ScanCommand}"
                        Style="{StaticResource ButtonPrimary}" />

                <Label Text="{Binding ScanStatusText}"
                       Style="{StaticResource MicroLabel}"
                       HorizontalOptions="Center" />

            </StackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
