<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mesh.Mobile.ViewModels"
             xmlns:models="clr-namespace:Mesh.Mobile.Core.Models;assembly=Mesh.Mobile.Core"
             x:Class="Mesh.Mobile.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="Messages">

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="0">

        <StackLayout Grid.Row="0"
                     Padding="16,16,16,12"
                     Spacing="4"
                     BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource DarkCardBg}}">
            <Label Text="Messagerie"
                   Style="{StaticResource TitleSection}" />
            <Label Text="Discutez rapidement avec les nœuds du réseau Mesh."
                   Style="{StaticResource TextSmall}" />
        </StackLayout>

        <BoxView Grid.Row="0"
                 Style="{StaticResource Separator}"
                 Margin="0"
                 VerticalOptions="End" />

        <Border Grid.Row="1"
                Style="{StaticResource CardDefault}"
                Margin="16,12,16,8"
                Padding="12">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <Label Grid.Column="0"
                       Text="ℹ️"
                       FontSize="18"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="Astuce: appuyez sur Envoyer pour diffuser votre message à proximité."
                       Style="{StaticResource MicroLabel}"
                       VerticalTextAlignment="Center" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="None"
                        Margin="16,8,16,16"
                        SelectionChangedCommand="{Binding SelectionChangedCommand}">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <StackLayout Padding="20,40"
                             Spacing="12"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <Label Text="📨"
                           FontSize="46"
                           HorizontalOptions="Center" />
                    <Label Text="Aucun message reçu"
                           Style="{StaticResource TextSmall}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Envoyez un premier message pour démarrer la conversation."
                           Style="{StaticResource MicroLabel}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MessageItem">
                    <Border Style="{StaticResource CardDefault}"
                            Padding="12">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    Padding="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightBgSecondary}, Dark={StaticResource DarkBgSecondary}}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 19">
                                <Label Text="{Binding SrcLabel, StringFormat='{0}'}"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightPrimaryNetwork}, Dark={StaticResource DarkPrimaryNetwork}}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <StackLayout Grid.Column="1"
                                         Spacing="4"
                                         VerticalOptions="Center">
                                <Label Text="{Binding Text}"
                                       Style="{StaticResource TextSmall}"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding TimeLabel}"
                                       Style="{StaticResource MicroLabel}" />
                            </StackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <BoxView Grid.Row="2"
                 Style="{StaticResource Separator}"
                 Margin="0"
                 VerticalOptions="End" />

        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10"
              Padding="16"
              BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource DarkCardBg}}">

            <Entry Grid.Column="0"
                   Style="{StaticResource InputDefault}"
                   Placeholder="Écrire un message au réseau…"
                   ReturnType="Send"
                   Text="{Binding MessageText}"
                   ReturnCommand="{Binding SendCommand}" />

            <Button Grid.Column="1"
                    Text="Envoyer"
                    Style="{StaticResource ButtonPrimary}"
                    Padding="14,0"
                    Command="{Binding SendCommand}" />
        </Grid>

    </Grid>
</ContentPage>
